{
  "name": "healthagent",
  "version": "1.0.0",
  "description": "AI-powered healthcare navigator and caregiver command center",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "deploy": "gcloud run deploy health-agent --source . --region us-central1 --port 3000",
    "deploy:hk": "gcloud run deploy health-agent-hk --source . --region asia-east2 --port 3000",
    "cap:init": "npx cap init 'Health Agent' com.healthagent.app --web-dir public",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@vapi-ai/server-sdk": "^0.11.0",
    "anthropic": "^0.0.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "duck-duck-scrape": "^2.2.7",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "ical-generator": "^10.0.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^2.4.5",
    "pdf-poppler": "^0.2.3",
    "pdfjs-dist": "^5.5.207",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0"
  }
}
