  <button class="bn-tab" id="navHome" onclick="setMobileState('home')"><span class="bn-icon">🏠</span>Home</button>
  <button class="bn-tab active" id="navChat" onclick="setMobileState('chat')"><span class="bn-icon">💬</span>Chat</button>
