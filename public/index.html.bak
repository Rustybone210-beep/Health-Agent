<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<title>Health Agent</title>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet" />

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#08090f;
  --surface:rgba(18,22,38,0.88);
  --surface-2:rgba(24,29,46,0.9);
  --surface-3:rgba(31,37,58,0.96);
  --border:rgba(255,255,255,0.07);
  --border-2:rgba(255,255,255,0.12);
  --teal:#2dd4bf;
  --teal2:#0d9488;
  --gold:#d4a843;
  --gold2:#b8860b;
  --danger:#f87171;
  --warn:#fb923c;
  --info:#60a5fa;
  --text:#f0f2f8;
  --text2:#8892aa;
  --text3:#404860;
  --textInv:#06080e;
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bot:env(safe-area-inset-bottom,20px);
  --topbar-h:56px;
  --botnav-h:62px;
  --radius-card:22px;
  --radius-bubble:16px;
  --radius-btn:10px;
  --shadow-soft:0 10px 30px rgba(0,0,0,0.22);
  --shadow-card:0 6px 20px rgba(0,0,0,0.18);
  --sans:'DM Sans',sans-serif;
  --serif:'DM Serif Display',serif;
}
html,body{
  height:100%;
  height:100dvh;
  font-family:var(--sans);
  background:var(--bg);
  color:var(--text);
  overflow:hidden;
  -webkit-font-smoothing:antialiased;
}
body.modal-open{overflow:hidden}
button,input,textarea,select{font:inherit}
a{color:inherit;text-decoration:none}
.hidden{display:none!important}
.muted{color:var(--text2)}
small{font-size:12px}
pre,code{font-family:ui-monospace,SFMono-Regular,Menlo,monospace}

.app{
  display:flex;
  height:100dvh;
  overflow:hidden;
  position:relative;
  background:radial-gradient(circle at top center, rgba(45,212,191,0.035), transparent 28%), var(--bg);
}

/* MOBILE TOP BAR */
.topbar{
  display:none;
  position:fixed;
  top:0;left:0;right:0;
  z-index:120;
  height:calc(var(--topbar-h) + var(--safe-top));
  padding:var(--safe-top) 16px 0;
  background:rgba(8,9,15,0.92);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  align-items:center;
  justify-content:space-between;
}
.tb-title{
  font-family:var(--serif);
  font-size:18px;
  color:var(--text);
}
.tb-right{
  display:flex;
  align-items:center;
  gap:12px;
}
.tb-bell{
  position:relative;
  background:none;
  border:none;
  color:var(--text2);
  font-size:20px;
  cursor:pointer;
  width:32px;height:32px;
  display:flex;align-items:center;justify-content:center;
}
.tb-avatar{
  width:36px;height:36px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  border:2px solid rgba(212,168,67,0.38);
  color:#101114;
  font-family:var(--serif);
  font-size:14px;
  font-weight:700;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 12px rgba(212,168,67,0.22);
  cursor:pointer;
}
.notif-badge{
  position:absolute;
  top:0;right:0;
  min-width:16px;height:16px;
  padding:0 4px;
  border-radius:999px;
  display:flex;align-items:center;justify-content:center;
  background:var(--danger);
  color:#fff;
  font-size:9px;
  font-weight:700;
  border:1.5px solid var(--bg);
}

/* DESKTOP SIDEBAR */
.sidebar{
  width:288px;
  flex-shrink:0;
  display:flex;
  flex-direction:column;
  background:rgba(8,9,15,0.97);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border-right:1px solid var(--border);
  overflow:hidden;
  z-index:40;
}
.sb-head{
  padding:20px 16px 14px;
  border-bottom:1px solid var(--border);
  flex-shrink:0;
}
.sb-brand{
  display:flex;align-items:center;gap:10px;
  margin-bottom:14px;
}
.sb-logo{
  width:34px;height:34px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,var(--teal),var(--teal2));
  box-shadow:0 3px 10px rgba(45,212,191,0.24);
  font-size:16px;
}
.sb-name{
  font-family:var(--serif);
  font-size:17px;
}
.pat-btn{
  width:100%;
  background:var(--surface-2);
  border:1px solid var(--border-2);
  border-radius:12px;
  padding:9px 11px;
  color:var(--text);
  font-size:13px;
  cursor:pointer;
  display:flex;align-items:center;justify-content:space-between;
  gap:8px;
  text-align:left;
}
.pat-btn:hover{border-color:rgba(45,212,191,0.25)}
.pat-name{font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pat-rel{font-size:11px;color:var(--text2);margin-top:2px}
.pat-dd{
  display:none;
  position:absolute;
  left:0;right:0;top:calc(100% + 6px);
  background:rgba(10,12,22,0.98);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border:1px solid var(--border-2);
  border-radius:12px;
  overflow:hidden;
  z-index:300;
  box-shadow:0 10px 30px rgba(0,0,0,0.45);
}
.pat-dd.open{display:block}
.pat-opt{padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);font-size:13px}
.pat-opt:hover{background:rgba(45,212,191,0.06)}
.pat-opt.active{background:rgba(45,212,191,0.1)}
.opt-n{font-weight:600}
.opt-r{font-size:11px;color:var(--text2);margin-top:2px}
.add-pat{padding:10px 14px;cursor:pointer;font-size:13px;color:var(--teal)}
.add-pat:hover{background:rgba(45,212,191,0.06)}

.sb-scroll{
  flex:1;
  overflow-y:auto;
  padding:12px;
  scrollbar-width:none;
}
.sb-scroll::-webkit-scrollbar{display:none}
.s-lbl{
  font-size:10px;
  font-weight:700;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--text3);
  margin-bottom:7px;
}
.sb-card{
  background:linear-gradient(135deg,rgba(212,168,67,0.12),rgba(212,168,67,0.04));
  border:1px solid rgba(212,168,67,0.14);
  border-radius:var(--radius-card);
  padding:14px;
  margin-bottom:12px;
}
.pc-row{display:flex;gap:6px;margin-bottom:5px;font-size:12px}
.pc-l{width:62px;flex-shrink:0;color:var(--text3);font-size:11px}
.pc-v{color:var(--text);line-height:1.4}
.pill-row{display:flex;flex-wrap:wrap;gap:4px;margin-top:4px}
.pill{
  display:inline-flex;align-items:center;
  padding:3px 8px;
  border-radius:999px;
  font-size:10px;
  font-weight:500;
}
.p-teal{background:rgba(45,212,191,0.1);border:1px solid rgba(45,212,191,0.18);color:var(--teal)}
.p-red{background:rgba(248,113,113,0.1);border:1px solid rgba(248,113,113,0.18);color:var(--danger)}
.p-gold{background:rgba(212,168,67,0.1);border:1px solid rgba(212,168,67,0.18);color:var(--gold)}

.hist-item{
  padding:8px 9px;border-radius:10px;cursor:pointer;margin-bottom:2px;
  font-size:12px;color:var(--text2);display:flex;align-items:flex-start;gap:6px;
  border:1px solid transparent;transition:all 0.15s
}
.hist-item:hover{background:var(--surface-2);color:var(--text);border-color:var(--border)}
.hist-item.active{background:rgba(45,212,191,0.08);color:var(--text);border-color:rgba(45,212,191,0.18)}
.hist-content{flex:1;overflow:hidden}
.hist-preview{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hist-time{font-size:10px;color:var(--text3);margin-top:2px}
.hist-del{
  opacity:0;background:none;border:none;color:var(--danger);cursor:pointer;
  padding:2px;font-size:11px;transition:opacity 0.15s;flex-shrink:0
}
.hist-item:hover .hist-del{opacity:1}
.new-chat-btn{
  background:rgba(45,212,191,0.08);
  border:1px solid rgba(45,212,191,0.18);
  color:var(--teal);
  font-size:11px;
  padding:3px 8px;
  border-radius:999px;
  cursor:pointer;
}
.sb-nav{display:flex;flex-direction:column;gap:3px}
.sb-link{
  display:flex;align-items:center;gap:8px;
  padding:9px 10px;border-radius:10px;
  font-size:12px;color:var(--text2);
  background:none;border:none;cursor:pointer;text-align:left;width:100%;
  transition:all 0.15s
}
.sb-link:hover{background:var(--surface-2);color:var(--text)}
.qa-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.qa-btn{
  background:var(--surface-2);
  border:1px solid var(--border);
  border-radius:10px;
  padding:10px 8px;
  color:var(--text2);
  font-size:11px;
  cursor:pointer;
  text-align:center;
  transition:all 0.15s
}
.qa-btn:hover{background:var(--surface-3);color:var(--text)}
.qa-icon{display:block;font-size:14px;margin-bottom:3px}
.gcal-s{
  display:inline-flex;align-items:center;gap:6px;
  font-size:11px;padding:5px 10px;border-radius:999px;
  background:rgba(45,212,191,0.08);
  border:1px solid rgba(45,212,191,0.18);
  color:var(--teal)
}
.gcal-s.nc{
  background:rgba(251,146,60,0.08);
  border-color:rgba(251,146,60,0.18);
  color:var(--warn)
}

/* DESKTOP TOP BAR */
.desk-topbar{
  height:56px;
  background:rgba(8,9,15,0.9);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;
  padding:0 20px;
  gap:12px;
  flex-shrink:0;
}
.desk-title{
  flex:1;
  font-family:var(--serif);
  font-size:18px;
}
.status-dot{
  width:7px;height:7px;border-radius:50%;
  background:var(--teal);
  box-shadow:0 0 8px var(--teal);
  animation:pdot 2.5s ease infinite
}
@keyframes pdot{0%,100%{opacity:1}50%{opacity:0.4}}
.notif-btn{
  position:relative;
  width:34px;height:34px;border-radius:50%;
  background:var(--surface-2);
  border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  color:var(--text2);
  font-size:15px;
  cursor:pointer;
}
.notif-btn:hover{background:var(--surface-3);color:var(--text)}

/* MAIN */
.main{
  flex:1;
  min-width:0;
  display:flex;
  flex-direction:column;
  overflow:hidden;
  position:relative;
}

/* MOBILE STATES */
.mobile-state{
  display:none;
  flex:1;
  min-height:0;
}
.mobile-state.active{
  display:flex;
  flex-direction:column;
  animation:fadeState 0.18s ease;
}
@keyframes fadeState{from{opacity:0}to{opacity:1}}

/* DASHBOARD */
.dashboard-wrap{
  flex:1;
  overflow-y:auto;
  padding:14px 14px 12px;
}
.dash-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}
.dash-card{
  background:var(--surface);
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
  border:1px solid var(--border);
  border-radius:var(--radius-card);
  padding:16px;
  min-height:118px;
  box-shadow:var(--shadow-card);
  cursor:pointer;
  transition:transform 0.15s ease, border-color 0.15s ease;
}
.dash-card:active{transform:scale(0.98)}
.dash-card:hover{border-color:rgba(45,212,191,0.14)}
.dash-label{
  font-size:10px;
  font-weight:700;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--text3);
  margin-bottom:10px;
}
.dash-value{
  font-family:var(--serif);
  font-size:30px;
  line-height:1;
  margin-bottom:8px;
}
.dash-sub{
  font-size:13px;
  color:var(--text2);
  line-height:1.45;
}
.activity-list{
  margin-top:18px;
  display:flex;
  flex-direction:column;
  gap:8px;
}
.activity-item{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:16px;
  padding:12px 14px;
}
.activity-title{
  font-size:13px;
  font-weight:600;
  color:var(--text);
}
.activity-sub{
  font-size:11px;
  color:var(--text3);
  margin-top:3px;
}

/* CHAT */
.chat-wrap{
  flex:1;
  min-height:0;
  display:flex;
  flex-direction:column;
}
.chat-area{
  flex:1;
  min-height:0;
  overflow-y:auto;
  padding:14px 14px 10px;
  display:flex;
  flex-direction:column;
  gap:8px;
  scroll-behavior:smooth;
  -webkit-overflow-scrolling:touch;
  scrollbar-width:none;
}
.chat-area::-webkit-scrollbar{display:none}

.welcome-inline{
  padding:8px 2px 10px;
  animation:msgIn 0.2s ease;
}
.welcome-inline-title{
  font-size:18px;
  line-height:1.5;
  color:var(--text);
  margin-bottom:10px;
}
.chip-row{
  display:flex;
  flex-wrap:wrap;
  gap:8px;
}
.chip{
  padding:8px 12px;
  border-radius:999px;
  background:rgba(45,212,191,0.06);
  border:1px solid rgba(45,212,191,0.14);
  color:var(--text2);
  font-size:13px;
  cursor:pointer;
  transition:all 0.15s
}
.chip:hover{background:rgba(45,212,191,0.1);color:var(--text)}
.chip:active{transform:scale(0.96)}

.msg{
  display:flex;
  gap:8px;
  max-width:88%;
  animation:msgIn 0.2s ease;
}
@keyframes msgIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.msg.user{margin-left:auto;flex-direction:row-reverse}
.msg-avatar{
  width:28px;height:28px;border-radius:50%;
  flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:12px;
  margin-top:2px;
  border:1px solid var(--border);
}
.msg.ai .msg-avatar{background:var(--surface-2)}
.msg.user .msg-avatar{
  background:linear-gradient(135deg,var(--teal),var(--teal2));
  border-color:rgba(45,212,191,0.24)
}
.msg-bubble{
  max-width:100%;
  word-wrap:break-word;
  padding:13px 15px;
  font-size:16px;
  line-height:1.6;
  color:var(--text);
  border-radius:18px;
}
.msg.ai .msg-bubble{
  background:var(--surface);
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
  border:1px solid var(--border);
  border-bottom-left-radius:6px;
}
.msg.user .msg-bubble{
  background:linear-gradient(135deg,var(--teal),var(--teal2));
  color:var(--textInv);
  border-bottom-right-radius:6px;
  box-shadow:0 4px 16px rgba(45,212,191,0.24);
}
.msg-bubble strong{font-weight:700}
.msg-bubble em{font-style:italic}
.msg-bubble code{
  background:rgba(255,255,255,0.08);
  padding:2px 6px;
  border-radius:6px;
  font-size:13px;
}
.msg-bubble pre{
  margin-top:10px;
  white-space:pre-wrap;
  word-break:break-word;
  background:rgba(0,0,0,0.26);
  padding:10px;
  border-radius:10px;
  font-size:12px;
  line-height:1.45;
}
.msg-bubble a{color:inherit;text-decoration:underline}

.typing-indicator{display:flex;gap:4px;align-items:center}
.typing-indicator span{
  width:6px;height:6px;border-radius:50%;
  background:var(--text3);
  animation:tb 1.3s ease infinite
}
.typing-indicator span:nth-child(2){animation-delay:0.18s}
.typing-indicator span:nth-child(3){animation-delay:0.36s}
@keyframes tb{0%,60%,100%{transform:translateY(0);opacity:0.45}30%{transform:translateY(-5px);opacity:1}}

/* ACTION CARDS */
.action-card{
  background:var(--surface);
  backdrop-filter:blur(16px);
  -webkit-backdrop-filter:blur(16px);
  border:1px solid var(--border);
  border-radius:var(--radius-card);
  padding:14px;
  margin:2px 0;
  font-size:13px;
  animation:msgIn 0.2s ease;
  max-width:88%;
  box-shadow:var(--shadow-card);
}
.action-card.calendar{border-color:rgba(45,212,191,0.18)}
.action-card.call{border-color:rgba(251,146,60,0.24)}
.action-card.email{border-color:rgba(139,92,246,0.22)}
.ac-title{
  font-size:10px;
  font-weight:700;
  letter-spacing:0.07em;
  text-transform:uppercase;
  color:var(--text3);
  margin-bottom:7px;
}
.ac-body{
  color:var(--text2);
  margin-bottom:10px;
  line-height:1.55;
  font-size:13px;
}
.ac-btns{display:flex;gap:7px;flex-wrap:wrap}
.ac-btn{
  padding:8px 14px;
  border-radius:999px;
  font-size:13px;
  font-weight:600;
  cursor:pointer;
  border:none;
  transition:all 0.15s;
}
.ac-btn:active{transform:scale(0.95)}
.ac-btn.primary,.ac-btn.success{
  background:linear-gradient(135deg,var(--teal),var(--teal2));
  color:var(--textInv);
}
.ac-btn.secondary{
  background:var(--surface-2);
  border:1px solid var(--border);
  color:var(--text2);
}
.ac-btn.warn{
  background:linear-gradient(135deg,var(--warn),#ea580c);
  color:#fff;
}

/* SCAN */
.scan-card{
  background:var(--surface-3);
  border:1px solid var(--border-2);
  border-radius:var(--radius-card);
  padding:16px;
  box-shadow:var(--shadow-soft);
}
.scan-header{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.scan-icon{font-size:22px}
.scan-title{font-family:var(--serif);font-size:18px}
.scan-badges{display:flex;gap:6px;flex-wrap:wrap;margin-left:auto}
.scan-badge{
  font-size:10px;padding:4px 8px;border-radius:999px;border:1px solid var(--border-2);
  letter-spacing:0.04em;text-transform:uppercase
}
.scan-badge.safe{color:var(--teal);background:rgba(45,212,191,0.08);border-color:rgba(45,212,191,0.18)}
.scan-badge.warn{color:var(--warn);background:rgba(251,146,60,0.08);border-color:rgba(251,146,60,0.18)}
.scan-badge.info{color:var(--info);background:rgba(96,165,250,0.08);border-color:rgba(96,165,250,0.18)}
.scan-card p{font-size:13px;color:var(--text2);line-height:1.55;margin-bottom:12px}
.scan-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.scan-field{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,0.05);
  border-radius:14px;
  padding:10px 11px;
}
.scan-field.full{grid-column:1 / -1}
.scan-label{
  display:block;
  font-size:10px;
  font-weight:700;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--text3);
  margin-bottom:4px;
}
.scan-value{
  font-size:13px;
  color:var(--text);
  line-height:1.45;
}
.scan-actions{margin-top:14px;display:flex;gap:8px;flex-wrap:wrap}
.scan-btn{
  padding:8px 12px;
  border-radius:10px;
  border:1px solid var(--border-2);
  background:var(--surface-2);
  font-size:13px;
  color:var(--text);
  cursor:pointer;
}
.scan-btn.primary{
  background:linear-gradient(135deg,var(--teal),var(--teal2));
  color:var(--textInv);
  border:none;
}
.scan-foot{
  margin-top:12px;
  padding-top:12px;
  border-top:1px solid var(--border);
  font-size:12px;
  color:var(--text3);
}

/* INPUT */
.input-bar{
  flex-shrink:0;
  background:rgba(8,9,15,0.96);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border-top:1px solid var(--border);
  padding:10px 14px calc(10px + var(--safe-bot));
}
.input-row{
  display:flex;
  gap:10px;
  align-items:flex-end;
}
.chat-input{
  flex:1;
  background:var(--surface);
  border:1px solid var(--border-2);
  border-radius:999px;
  padding:12px 16px;
  color:var(--text);
  font-size:16px;
  resize:none;
  outline:none;
  max-height:120px;
  min-height:46px;
  line-height:1.45;
  appearance:none;
  -webkit-appearance:none;
  transition:border-color 0.2s ease;
}
.chat-input:focus{
  border-color:rgba(45,212,191,0.32);
  box-shadow:0 0 0 3px rgba(45,212,191,0.06);
}
.chat-input::placeholder{color:var(--text3)}
.send-btn{
  width:46px;height:46px;border-radius:50%;
  flex-shrink:0;
  background:linear-gradient(135deg,var(--teal),var(--teal2));
  border:none;
  color:var(--textInv);
  font-size:18px;
  cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 16px rgba(45,212,191,0.24);
  transition:transform 0.15s ease;
}
.send-btn:active{transform:scale(0.95)}
.tool-row{
  display:flex;
  justify-content:center;
  gap:12px;
  margin-top:10px;
}
.tool-btn{
  width:36px;height:36px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  background:var(--surface);
  border:1px solid var(--border);
  color:var(--text2);
  font-size:17px;
  cursor:pointer;
  transition:all 0.15s ease;
}
.tool-btn:hover{background:var(--surface-2);color:var(--text)}
.tool-btn:active{transform:scale(0.95)}
.upload-pending{
  display:none;
  margin-top:10px;
  padding:6px 12px;
  border-radius:999px;
  background:rgba(45,212,191,0.06);
  border:1px solid rgba(45,212,191,0.14);
  color:var(--teal);
  font-size:12px;
  align-items:center;
  gap:6px;
}
.upload-pending.show{display:flex}

/* BOTTOM NAV */
.bot-nav{
  display:none;
  position:fixed;
  left:0;right:0;bottom:0;
  z-index:90;
  height:calc(var(--botnav-h) + var(--safe-bot));
  padding-bottom:var(--safe-bot);
  background:rgba(8,9,15,0.97);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border-top:1px solid var(--border);
  align-items:stretch;
}
.bn-tab{
  flex:1;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:3px;
  border:none;
  background:none;
  color:var(--text3);
  font-size:9px;
  font-weight:700;
  letter-spacing:0.05em;
  text-transform:uppercase;
  cursor:pointer;
}
.bn-tab:active{opacity:0.75}
.bn-icon{font-size:21px;line-height:1}
.bn-tab.active{color:var(--teal)}
.bn-tab.active .bn-icon{filter:drop-shadow(0 0 6px rgba(45,212,191,0.35))}

/* PROFILE SHEET */
.profile-sheet{
  display:none;
  position:fixed;
  inset:0;
  z-index:400;
}
.profile-sheet.open{display:block}
.ps-backdrop{
  position:absolute;inset:0;
  background:rgba(0,0,0,0.58);
  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);
}
.ps-card{
  position:absolute;
  top:0;left:0;right:0;
  background:rgba(12,14,24,0.98);
  border-bottom-left-radius:28px;
  border-bottom-right-radius:28px;
  padding:calc(var(--safe-top) + 16px) 20px 24px;
  box-shadow:0 18px 60px rgba(0,0,0,0.56);
  animation:slideDown 0.3s cubic-bezier(0.4,0,0.2,1);
  max-height:88dvh;
  overflow-y:auto;
}
@keyframes slideDown{from{transform:translateY(-100%)}to{transform:translateY(0)}}
.ps-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.ps-pat-info{display:flex;align-items:center;gap:12px}
.ps-avatar{
  width:56px;height:56px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold),var(--gold2));
  display:flex;align-items:center;justify-content:center;
  font-family:var(--serif);
  font-size:22px;
  font-weight:700;
  color:#101114;
  border:2px solid rgba(212,168,67,0.36);
  box-shadow:0 4px 14px rgba(212,168,67,0.22);
}
.ps-name{font-family:var(--serif);font-size:24px;line-height:1.1}
.ps-sub{font-size:13px;color:var(--gold);margin-top:3px;font-weight:500}
.ps-close{
  width:34px;height:34px;border-radius:50%;
  background:var(--surface-2);
  border:1px solid var(--border);
  color:var(--text2);
  font-size:18px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;
}
.ps-stats{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:8px;
  margin-bottom:18px;
}
.ps-stat{
  background:rgba(212,168,67,0.08);
  border:1px solid rgba(212,168,67,0.15);
  border-radius:14px;
  padding:12px 10px;
  text-align:center;
}
.ps-stat-n{font-family:var(--serif);font-size:24px;font-weight:700}
.ps-stat-l{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;margin-top:2px}
.ps-section{margin-bottom:12px}
.ps-section-title{
  font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3);margin-bottom:6px
}
.ps-row{display:flex;gap:6px;margin-bottom:6px;font-size:13px}
.ps-rl{width:72px;flex-shrink:0;color:var(--text3);font-size:12px;padding-top:1px}
.ps-rv{flex:1;color:var(--text2);line-height:1.4}
.ps-expand{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:16px;
  overflow:hidden;
  margin-bottom:8px;
}
.ps-expand-btn{
  width:100%;
  background:none;
  border:none;
  color:var(--text);
  padding:13px 14px;
  display:flex;align-items:center;justify-content:space-between;
  cursor:pointer;
  text-align:left;
}
.ps-expand-body{
  display:none;
  padding:0 14px 14px;
}
.ps-expand.open .ps-expand-body{display:block}

/* MENU SHEET */
.menu-sheet{
  display:none;
  position:fixed;
  inset:0;
  z-index:400;
}
.menu-sheet.open{display:block}
.ms-backdrop{
  position:absolute;inset:0;
  background:rgba(0,0,0,0.64);
  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);
}
.ms-panel{
  position:absolute;
  left:0;right:0;bottom:0;
  background:rgba(12,14,24,0.98);
  border-top-left-radius:28px;
  border-top-right-radius:28px;
  padding:10px 20px calc(20px + var(--safe-bot));
  box-shadow:0 -16px 50px rgba(0,0,0,0.5);
  animation:slideUp 0.3s cubic-bezier(0.4,0,0.2,1);
}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.ms-handle{width:38px;height:4px;background:var(--text3);border-radius:999px;margin:8px auto 16px}
.ms-title{font-family:var(--serif);font-size:18px;margin-bottom:14px}
.ms-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.ms-item{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:18px;
  padding:16px 10px;
  text-align:center;
  cursor:pointer;
  display:flex;flex-direction:column;align-items:center;gap:7px;
}
.ms-item:active{transform:scale(0.96)}
.ms-icon{font-size:24px}
.ms-label{font-size:11px;font-weight:600;color:var(--text2)}

/* TASK PANEL */
#taskPanel{
  display:none;
  position:fixed;
  top:0;right:0;bottom:0;
  width:min(420px,100vw);
  background:rgba(8,9,15,0.98);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border-left:1px solid var(--border);
  z-index:500;
  flex-direction:column;
  overflow:hidden;
  box-shadow:-16px 0 48px rgba(0,0,0,0.45);
}
#taskPanel.open{display:flex;animation:slideR 0.3s ease}
@keyframes slideR{from{transform:translateX(100%)}to{transform:translateX(0)}}
.task-tab{
  padding:5px 12px;
  border-radius:999px;
  font-size:12px;
  cursor:pointer;
  border:1px solid var(--border);
  background:transparent;
  color:var(--text2);
}
.task-tab.active{
  background:rgba(45,212,191,0.08);
  border-color:rgba(45,212,191,0.18);
  color:var(--teal);
}
.task-item{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:14px;
  padding:12px 13px;
  margin-bottom:6px;
  animation:msgIn 0.2s ease
}
.task-item.done{opacity:0.55}
.ti-head{display:flex;align-items:flex-start;gap:8px;margin-bottom:4px}
.task-checkbox{width:16px;height:16px;flex-shrink:0;margin-top:2px;accent-color:var(--teal);cursor:pointer}
.t-title{font-size:13px;font-weight:600;flex:1;line-height:1.3}
.t-title.done{text-decoration:line-through;color:var(--text3)}
.t-desc{font-size:12px;color:var(--text2);margin:3px 0 7px 24px;line-height:1.5}
.t-meta{display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-left:24px}
.t-due{font-size:11px;color:var(--text3)}
.t-due.ov{color:var(--danger);font-weight:600}
.t-pri{font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px}
.pri-high{background:rgba(248,113,113,0.1);color:var(--danger)}
.pri-medium{background:rgba(251,146,60,0.08);color:var(--warn)}
.pri-low{background:rgba(45,212,191,0.08);color:var(--teal)}
.t-acts{display:flex;gap:5px;margin-top:7px;margin-left:24px}
.t-act{
  padding:3px 9px;border-radius:8px;font-size:11px;cursor:pointer;border:1px solid var(--border);
  background:var(--surface-2);color:var(--text2)
}
.t-act.del{color:var(--danger)}

/* MODALS */
.modal{
  display:none;
  position:fixed;
  inset:0;
  z-index:600;
  align-items:center;
  justify-content:center;
  padding:20px;
  background:rgba(0,0,0,0.75);
  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);
}
.modal.open{display:flex}
.modal-box{
  position:relative;
  width:100%;
  max-width:520px;
  max-height:90dvh;
  overflow-y:auto;
  background:rgba(10,12,22,0.99);
  backdrop-filter:blur(24px);
  -webkit-backdrop-filter:blur(24px);
  border:1px solid var(--border-2);
  border-radius:var(--radius-card);
  padding:24px;
  box-shadow:0 20px 60px rgba(0,0,0,0.7);
  animation:modalIn 0.22s ease;
}
@keyframes modalIn{from{opacity:0;transform:scale(0.98) translateY(8px)}to{opacity:1;transform:scale(1) translateY(0)}}
.m-title{
  font-family:var(--serif);
  font-size:20px;
  margin-bottom:20px;
}
.f-field{margin-bottom:13px}
.f-lbl{
  display:block;
  font-size:10px;
  font-weight:700;
  text-transform:uppercase;
  letter-spacing:0.07em;
  color:var(--text3);
  margin-bottom:5px;
}
.f-inp{
  width:100%;
  background:var(--surface-2);
  border:1px solid var(--border);
  border-radius:10px;
  padding:10px 12px;
  color:var(--text);
  font-size:14px;
  outline:none
}
.f-inp:focus{border-color:rgba(45,212,191,0.32)}
.f-row{display:flex;gap:10px}
.f-row .f-field{flex:1}
.m-acts{display:flex;gap:9px;margin-top:20px}
.m-btn{
  flex:1;
  padding:11px;
  border-radius:10px;
  font-size:14px;
  font-weight:600;
  cursor:pointer;
  border:1px solid transparent;
}
.m-btn.cancel{
  background:var(--surface-2);
  border-color:var(--border);
  color:var(--text2);
}
.m-btn.save{
  background:linear-gradient(135deg,var(--teal),var(--teal2));
  color:var(--textInv);
}

/* RESPONSIVE */
@media(min-width:901px){
  .topbar,.bot-nav,.mobile-state{display:none!important}
  .sidebar{display:flex}
  .desk-topbar{display:flex}
  .desktop-chat{display:flex;flex-direction:column;flex:1;min-height:0}
}
@media(max-width:900px){
  .sidebar,.desk-topbar{display:none!important}
  .topbar{display:flex}
  .bot-nav{display:flex}
  .main{
    padding-top:calc(var(--topbar-h) + var(--safe-top));
    padding-bottom:calc(var(--botnav-h) + var(--safe-bot));
  }
  .desktop-chat{display:none!important}
  .msg{max-width:92%}
  .action-card{max-width:100%}
  .scan-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<header class="topbar" id="mobileTopbar">
  <span class="tb-title">Health Agent</span>
  <div class="tb-right">
    <button class="tb-bell" id="notifBtnMobileWrap" onclick="toggleNotifications()" aria-label="Notifications">
      🔔<span class="notif-badge" id="notifBadgeMobile" style="display:none"></span>
    </button>
    <div class="tb-avatar" id="mobilePatAvatar" onclick="openProfileSheet()" role="button" aria-label="Patient profile">LF</div>
  </div>
</header>

<div class="overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="app">
  <aside class="sidebar" id="sidebar">
    <div class="sb-head">
      <div class="sb-brand">
        <div class="sb-logo">🏥</div>
        <span class="sb-name">Health Agent</span>
      </div>
      <div style="position:relative" id="patientSelector">
        <button class="pat-btn" onclick="togglePatientDropdown()">
          <div style="flex:1;overflow:hidden">
            <div class="pat-name" id="selectorName">Loading...</div>
            <div class="pat-rel" id="selectorRel">—</div>
          </div>
          <span style="color:var(--text3);font-size:11px">▾</span>
        </button>
        <div class="pat-dd" id="patientDropdown"></div>
      </div>
    </div>

    <div class="sb-scroll">
      <div class="sb-card">
        <div class="s-lbl" style="margin-bottom:9px">Patient Profile</div>
        <div id="cardContent" style="color:var(--text3);font-size:12px">Loading...</div>
      </div>

      <div style="margin-bottom:12px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:7px">
          <span class="s-lbl" style="margin-bottom:0">💬 History</span>
          <button class="new-chat-btn" onclick="newChat()">+ New</button>
        </div>
        <div id="chatHistoryList"><div style="font-size:12px;color:var(--text3);padding:3px 0">No history yet</div></div>
      </div>

      <div style="margin-bottom:12px">
        <div class="s-lbl" style="margin-bottom:7px">Quick Actions</div>
        <div class="qa-grid">
          <button class="qa-btn" onclick="qa('What are her current medications?')"><span class="qa-icon">💊</span>Meds</button>
          <button class="qa-btn" onclick="qa('What are her upcoming appointments?')"><span class="qa-icon">📅</span>Appts</button>
          <button class="qa-btn" onclick="qa('Draft a prior authorization appeal letter for Medicare')"><span class="qa-icon">✉️</span>Letter</button>
          <button class="qa-btn" onclick="qa('What is her current insurance coverage?')"><span class="qa-icon">🛡️</span>Insurance</button>
          <button class="qa-btn" onclick="qa('Call Dr. Martinez at Alamo Heights Family Medicine')"><span class="qa-icon">📞</span>Call Doc</button>
          <button class="qa-btn" onclick="qa('Call Walgreens pharmacy at (210) 403-0002 about a refill')"><span class="qa-icon">🏪</span>Pharmacy</button>
        </div>
      </div>

      <div style="margin-bottom:12px">
        <div class="s-lbl" style="margin-bottom:7px">Pages</div>
        <div class="sb-nav">
          <a href="/timeline" class="sb-link">🕐 Medical Timeline</a>
          <a href="/playbooks" class="sb-link">🆘 Emergency Playbooks</a>
          <a href="/brief" class="sb-link">📋 Doctor Brief PDF</a>
          <button class="sb-link" onclick="openTaskPanel()">✅ Task Tracker <span id="taskBadge" style="margin-left:auto;background:var(--warn);color:#000;font-size:10px;font-weight:700;padding:1px 6px;border-radius:10px;display:none"></span></button>
          <button class="sb-link" onclick="openCalendarModal()">📅 Add Calendar Event</button>
        </div>
      </div>

      <div>
        <div class="s-lbl" style="margin-bottom:6px">Google Calendar</div>
        <a id="gcalStatus" href="/auth/google" target="_blank" class="gcal-s nc">⚠️ Connect Calendar</a>
      </div>
    </div>
  </aside>

  <div id="taskPanelOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:200;backdrop-filter:blur(2px)" onclick="closeTaskPanel()"></div>

  <div id="taskPanel">
    <div style="padding:16px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0;padding-top:calc(16px + var(--safe-top))">
      <span style="font-family:var(--serif);font-size:18px">✅ Tasks</span>
      <span style="flex:1"></span>
      <button onclick="openAddTask()" style="background:linear-gradient(135deg,var(--teal),var(--teal2));border:none;color:var(--textInv);padding:6px 13px;border-radius:999px;font-size:12px;cursor:pointer;font-weight:600">+ Add</button>
      <button onclick="closeTaskPanel()" style="background:none;border:none;color:var(--text2);font-size:22px;cursor:pointer;padding:4px;line-height:1">×</button>
    </div>

    <div style="display:flex;gap:5px;padding:9px 14px;border-bottom:1px solid var(--border);flex-shrink:0;flex-wrap:wrap">
      <button class="task-tab active" onclick="setTaskFilter('all',this)">All</button>
      <button class="task-tab" onclick="setTaskFilter('pending',this)">Pending</button>
      <button class="task-tab" onclick="setTaskFilter('in-progress',this)">In Progress</button>
      <button class="task-tab" onclick="setTaskFilter('done',this)">Done</button>
    </div>

    <div id="taskList" style="flex:1;overflow-y:auto;padding:10px"></div>
  </div>

  <main class="main">

    <!-- MOBILE: CHAT -->
    <section class="mobile-state active" id="mobileChatState">
      <div class="chat-wrap">
        <div class="chat-area" id="chatArea"></div>

        <div class="input-bar">
          <div class="input-row">
            <textarea class="chat-input" id="chatInput" placeholder="Message Health Agent..." rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
            <button class="send-btn" onclick="sendMessage()" aria-label="Send">➤</button>
          </div>

          <div class="tool-row">
            <button class="tool-btn" onclick="startVoiceCall()" aria-label="Call">📞</button>
            <button class="tool-btn" onclick="startEmailSend()" aria-label="Email">📧</button>
            <button class="tool-btn" onclick="triggerUpload()" aria-label="Scan">📷</button>
            <button class="tool-btn" onclick="openCalendarModal()" aria-label="Calendar">📅</button>
          </div>

          <div class="upload-pending" id="uploadPending">
            <span>📎</span><span id="uploadFileName">Uploading...</span>
          </div>
        </div>
      </div>
    </section>

    <!-- MOBILE: DASHBOARD -->
    <section class="mobile-state" id="mobileHomeState">
      <div class="dashboard-wrap">
        <div class="dash-grid">
          <button class="dash-card" onclick="goToDashboardCard('today')">
            <div class="dash-label">Today</div>
            <div class="dash-value" id="todayPrimary">All clear</div>
            <div class="dash-sub" id="todaySecondary">No urgent items right now</div>
          </button>

          <button class="dash-card" onclick="goToDashboardCard('upcoming')">
            <div class="dash-label">Upcoming</div>
            <div class="dash-value" id="upcomingPrimary">0</div>
            <div class="dash-sub" id="upcomingSecondary">No appointments loaded</div>
          </button>

          <button class="dash-card" onclick="goToDashboardCard('tasks')">
            <div class="dash-label">Tasks</div>
            <div class="dash-value" id="tasksPrimary">0</div>
            <div class="dash-sub" id="tasksSecondary">Nothing pending</div>
          </button>

          <button class="dash-card" onclick="goToDashboardCard('records')">
            <div class="dash-label">Records</div>
            <div class="dash-value" id="recordsPrimary">0</div>
            <div class="dash-sub" id="recordsSecondary">No recent uploads</div>
          </button>
        </div>

        <div class="activity-list" id="recentActivityList"></div>
      </div>
    </section>

    <!-- DESKTOP -->
    <section class="desktop-chat">
      <div class="desk-topbar">
        <div class="status-dot"></div>
        <span class="desk-title" id="desktopTitle">Health Dashboard</span>
        <span style="flex:1"></span>
        <button class="notif-btn" onclick="toggleNotifications()" id="notifBtnDesktop">🔔<span class="notif-badge" id="notifBadgeDesktop" style="display:none"></span></button>
      </div>

      <div class="chat-wrap">
        <div class="chat-area" id="desktopChatMirror" style="display:none"></div>
        <div class="chat-area" id="chatAreaDesktop"></div>

        <div class="input-bar">
          <div class="input-row">
            <textarea class="chat-input" id="chatInputDesktop" placeholder="Message Health Agent..." rows="1"></textarea>
            <button class="send-btn" onclick="sendMessageFromDesktop()" aria-label="Send">➤</button>
          </div>

          <div class="tool-row" style="justify-content:flex-start">
            <button class="tool-btn" onclick="startVoiceCall()" aria-label="Call">📞</button>
            <button class="tool-btn" onclick="startEmailSend()" aria-label="Email">📧</button>
            <button class="tool-btn" onclick="triggerUpload()" aria-label="Scan">📷</button>
            <button class="tool-btn" onclick="openCalendarModal()" aria-label="Calendar">📅</button>
          </div>
        </div>
      </div>
    </section>

    <div class="notif-panel" id="notifPanel">
      <div class="np-head">
        <span class="np-title">🔔 Notifications</span>
        <button class="np-mark" onclick="markAllRead()">Mark all read</button>
      </div>
      <div class="notif-list" id="notifList"><div class="ni-empty">No notifications</div></div>
    </div>

  </main>
</div>

