    </div>

    <div class="s-lbl" style="margin-bottom:10px">Choose Calendar</div>

    <div style="display:grid;gap:10px">
      <button class="sb-link" style="background:var(--surface);border:1px solid var(--border);padding:14px;border-radius:16px" onclick="addEventToAppleCalendar()">
        <span> iPhone / Apple Calendar</span>
      </button>
      <button class="sb-link" style="background:var(--surface);border:1px solid var(--border);padding:14px;border-radius:16px" onclick="addEventToGoogleCalendar()">
        <span>Google Calendar</span>
      </button>
      <button class="sb-link" style="background:var(--surface);border:1px solid var(--border);padding:14px;border-radius:16px" onclick="addEventToOutlookCalendar()">
        <span>Outlook Calendar</span>
      </button>
    </div>

    <div class="m-acts">
      <button class="m-btn cancel" onclick="closeCalendarModal()">Close</button>
    </div>
  </div>
</div>

<input type="file" id="fileInput" accept="image/*,.pdf" onchange="handleFileUpload(this)" />

<script>
'use strict';

const MODEL_NAME = 'claude-sonnet-4-20250514';

let currentMessages = [];
let currentSessionId = null;
let currentPatientId = null;
let allPatients = [];
let notifications = [];
let calendarConnected = false;
let pendingCalendarEvent = null;
let allTasks = [];
let taskFilter = 'all';
let latestScanData = null;
let mobileState = 'chat';

/* INIT */
window.addEventListener('DOMContentLoaded', async () => {
  try {
    bindDesktopInput();
    setMobileState('chat', false);
    seedCalendarDefaults();
    await loadPatients();
    clearChat();
    await Promise.all([
      loadChatHistory(),
      loadNotifications(),
      checkCalendarStatus()
    ]);
    updateDashboard();
    setTimeout(() => { loadTasks().catch(() => {}); }, 800);
  } catch (err) {
    console.error('init error', err);
    clearChat();
    addMsg('ai', `❌ ${esc(err.message || 'Failed to initialize app.')}`, true, false);
  }
});

/* API */
async function api(url, options = {}) {
  const res = await fetch(url, options);
  const contentType = res.headers.get('content-type') || '';
  let data = null;

  try {
    if (contentType.includes('application/json')) {
      data = await res.json();
    } else {
      const text = await res.text();
      data = text ? { raw: text } : {};
    }
  } catch (_) {
    data = {};
  }

  if (!res.ok) {
    throw new Error(data?.error || data?.message || `Request failed (${res.status})`);
  }

  return data || {};
}

/* HELPERS */
function lockBody(){ document.body.classList.add('modal-open'); }
function unlockBody(){ document.body.classList.remove('modal-open'); }

function esc(str){
  if (str === null || str === undefined) return '';
  return String(str)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#39;');
}

function formatAssistantText(text) {
  if (!text) return '';
  let safe = esc(text);

  safe = safe.replace(/```([\s\S]*?)```/g, (_m, code) => `<pre><code>${code.trim()}</code></pre>`);
  safe = safe.replace(/`([^`]+)`/g, '<code>$1</code>');
  safe = safe.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  safe = safe.replace(/__(.+?)__/g, '<strong>$1</strong>');
  safe = safe.replace(/\*(.+?)\*/g, '<em>$1</em>');
  safe = safe.replace(/\n/g, '<br>');

  return safe;
}

function setText(id, val) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

function calcAge(dob){
  if(!dob) return null;
  try{
    let birth;
    if (dob.includes('/')) {
      const p = dob.split('/');
      if (p.length !== 3) return null;
      birth = new Date(`${p[2]}-${String(p[0]).padStart(2,'0')}-${String(p[1]).padStart(2,'0')}`);
    } else {
      birth = new Date(dob);
    }
    if (Number.isNaN(birth.getTime())) return null;
    return Math.floor((Date.now() - birth.getTime()) / (365.25 * 24 * 3600 * 1000));
  } catch {
    return null;
  }
}

function formatRelTime(iso){
  if(!iso) return '';
  const ts = new Date(iso).getTime();
  if (Number.isNaN(ts)) return '';
  const diff = Date.now() - ts;
  const m = Math.floor(diff / 60000);
  if(m < 1) return 'just now';
  if(m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if(h < 24) return `${h}h ago`;
  const d = Math.floor(h / 24);
  if(d < 7) return `${d}d ago`;
  return new Date(ts).toLocaleDateString();
}

function formatTaskDate(iso){
  if(!iso) return '';
  const [y,m,d] = iso.split('-');
  if (!y || !m || !d) return iso;
  const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[Math.max(0, parseInt(m,10)-1)]} ${parseInt(d,10)}, ${y}`;
}

function getPatientById(id){
  return allPatients.find(p => p.id === id) || null;
}

function getRecentUploads(){
  try{
    const raw = localStorage.getItem('healthAgentRecentUploads');
    const parsed = raw ? JSON.parse(raw) : [];
    return Array.isArray(parsed) ? parsed : [];
  }catch{
    return [];
  }
}

function getRecentUploadCount(){
  return getRecentUploads().filter(x => !currentPatientId || x.patientId === currentPatientId).length;
}

function saveRecentUpload(upload){
  try{
    const current = getRecentUploads();
    current.unshift(upload);
    localStorage.setItem('healthAgentRecentUploads', JSON.stringify(current.slice(0, 12)));
  }catch(e){
    console.error('saveRecentUpload', e);
  }
}

function inferConfidence(data){
  // Use server-provided confidence if available
  if (data.confidence === 'high') return {label:'high confidence', className:'safe'};
  if (data.confidence === 'medium') return {label:'review advised', className:'warn'};
  if (data.confidence === 'low') return {label:'low confidence', className:'info'};
  // Fallback scoring
  let score = 0;
  if (data.document_type) score += 20;
  if (data.summary) score += 20;
  if (data.member_id || data.medication_name || data.test_names) score += 25;
  if (data.insurance_company || data.prescriber || data.lab_name) score += 15;
  if (data.confidence) score += 10;
  const keys = Object.keys(data).filter(k => data[k] && data[k] !== 'Unknown' && data[k] !== 'unclear');
  score += Math.min(keys.length * 3, 30);
  if (score >= 60) return {label:'high confidence', className:'safe'};
  if (score >= 35) return {label:'review advised', className:'warn'};
  return {label:'low confidence', className:'info'};
}

function normalizeUSPhone(phone){
  if(!phone) return '';
  const cleaned = String(phone).replace(/[^\d+]/g, '');
  if (cleaned.startsWith('+')) return cleaned;
  const digits = cleaned.replace(/\D/g, '');
  if (digits.length === 10) return `+1${digits}`;
  if (digits.length === 11 && digits.startsWith('1')) return `+${digits}`;
  return cleaned;
}

function toISODateTimeLocal(dateStr, timeStr){
  if(!dateStr) throw new Error('Date is required.');
  const time = timeStr || '09:00';
  const local = new Date(`${dateStr}T${time}:00`);
  if (Number.isNaN(local.getTime())) throw new Error('Invalid date or time.');
  return local;
}

function formatICSDate(date){
  const y = date.getUTCFullYear();
  const m = String(date.getUTCMonth() + 1).padStart(2,'0');
  const d = String(date.getUTCDate()).padStart(2,'0');
  const h = String(date.getUTCHours()).padStart(2,'0');
  const min = String(date.getUTCMinutes()).padStart(2,'0');
  const s = String(date.getUTCSeconds()).padStart(2,'0');
  return `${y}${m}${d}T${h}${min}${s}Z`;
}

function buildCalendarEventFromForm(){
  const title = document.getElementById('calTitle').value.trim();
  const date = document.getElementById('calDate').value;
  const time = document.getElementById('calTime').value;
  const duration = parseInt(document.getElementById('calDuration').value || '60', 10);
  const location = document.getElementById('calLocation').value.trim();
  const description = document.getElementById('calDescription').value.trim();

  if (!title) throw new Error('Calendar title is required.');
  if (!date) throw new Error('Calendar date is required.');

  const start = toISODateTimeLocal(date, time);
  const end = new Date(start.getTime() + Math.max(5, duration) * 60000);

  return {
    title,
    date,
    time: time || '09:00',
    duration: Math.max(5, duration),
    location,
    description,
    start,
    end
  };
}

function seedCalendarDefaults(){
  const titleEl = document.getElementById('calTitle');
  const dateEl = document.getElementById('calDate');
  const timeEl = document.getElementById('calTime');
  if (!titleEl || !dateEl || !timeEl) return;

  if (!dateEl.value) {
    const tomorrow = new Date(Date.now() + 86400000);
    dateEl.value = tomorrow.toISOString().split('T')[0];
  }
  if (!timeEl.value) timeEl.value = '09:00';
  if (!titleEl.value) titleEl.value = 'Medical appointment';
}

function isMobileView(){
  return window.innerWidth <= 900;
}

function setMobileState(state, animate = true){
  mobileState = state;
  document.querySelectorAll('.mobile-state').forEach(el => el.classList.remove('active'));

  if (state === 'chat') document.getElementById('mobileChatState').classList.add('active');
  if (state === 'home') document.getElementById('mobileHomeState').classList.add('active');

  document.getElementById('navHome')?.classList.toggle('active', state === 'home');
  document.getElementById('navChat')?.classList.toggle('active', state === 'chat');
}

function goToDashboardCard(type){
  if (type === 'tasks') {
    openTaskPanel();
    return;
  }
  if (type === 'records') {
    setMobileState('chat');
    addMsg('ai', 'Recent records are visible after scans are saved. Scan a document or bottle to start building the record list.', true, false);
    return;
  }
  if (type === 'upcoming') {
    setMobileState('chat');
    qa('What are her upcoming appointments?');
    return;
  }
  if (type === 'today') {
    setMobileState('chat');
    qa('What needs attention today?');
  }
}

function toggleExpand(id){
  document.getElementById(id)?.classList.toggle('open');
}

function openSettingsPlaceholder(){
  closeMenuSheet();
  addMsg('ai', '⚙️ Settings screen coming next. Right now, the core care tools are chat, tasks, scans, calendar, and patient switching.', true, false);
  setMobileState('chat');
}

/* DASHBOARD */
function updateTopbarTitle(patient){
  const n = patient?.name || 'Health Dashboard';
  setText('desktopTitle', `${n} — Health Dashboard`);
}

function renderRecentRecords(){
  const list = document.getElementById('recentActivityList');
  if(!list) return;

  const uploads = getRecentUploads().filter(x => !currentPatientId || x.patientId === currentPatientId).slice(0, 3);

  if (!uploads.length) {
    list.innerHTML = `
      <div class="activity-item">
        <div class="activity-title">No recent activity yet</div>
        <div class="activity-sub">Scans, saved records, and care actions will appear here.</div>
      </div>
    `;
    return;
  }

  list.innerHTML = uploads.map(item => `
    <div class="activity-item">
      <div class="activity-title">${esc(item.title || item.name || 'Recent record')}</div>
      <div class="activity-sub">${esc(item.type || 'Record')} · ${formatRelTime(item.at)}</div>
    </div>
  `).join('');
}

function updateDashboard(){
  const pendingTasks = allTasks.filter(t => t.status !== 'done');
  const highPriorityTasks = pendingTasks.filter(t => t.priority === 'high');
  const today = new Date().toISOString().split('T')[0];
  const dueToday = pendingTasks.filter(t => t.dueDate === today);

  let todayPrimary = 'All clear';
  let todaySecondary = 'No urgent items right now';

  if (highPriorityTasks.length > 0) {
    todayPrimary = `${highPriorityTasks.length} urgent`;
    todaySecondary = 'High priority items need attention';
  } else if (dueToday.length > 0) {
    todayPrimary = `${dueToday.length} due today`;
    todaySecondary = 'Tasks scheduled for today';
  } else if (pendingTasks.length > 0) {
    todayPrimary = `${pendingTasks.length} open`;
    todaySecondary = 'Pending care tasks in progress';
  }

  setText('todayPrimary', todayPrimary);
  setText('todaySecondary', todaySecondary);

  setText('upcomingPrimary', '0');
  setText('upcomingSecondary', 'Appointments coming soon');

  setText('tasksPrimary', String(pendingTasks.length));
  setText('tasksSecondary', pendingTasks.length > 0 ? 'Open items requiring follow-up' : 'Nothing pending');

  const recordsCount = getRecentUploadCount();
  setText('recordsPrimary', String(recordsCount));
  setText('recordsSecondary', recordsCount > 0 ? 'Recent files scanned or uploaded' : 'No recent uploads');

  renderRecentRecords();
}

/* PATIENTS */
async function loadPatients(){
  const [patientsData, currentData] = await Promise.all([
    api('/api/patients'),
    api('/api/patients/current')
  ]);

  allPatients = Array.isArray(patientsData.patients) ? patientsData.patients : [];
  currentPatientId = currentData.currentId || allPatients[0]?.id || null;

  const currentPatient =
    currentData.patient ||
    allPatients.find(p => p.id === currentPatientId) ||
    allPatients[0] ||
    null;

  renderPatientDropdown();
  renderPatientCard(currentPatient);
  renderProfileSheet(currentPatient);
  updateTopbarTitle(currentPatient);
}

function renderPatientDropdown(){
  const dd = document.getElementById('patientDropdown');
  if(!dd) return;

  const current = allPatients.find(p => p.id === currentPatientId);
  setText('selectorName', current?.name || 'No Patient');
  setText('selectorRel', current?.relationship || current?.relation || 'Family Member');

  dd.innerHTML = allPatients.map(p => `
    <div class="pat-opt ${p.id === currentPatientId ? 'active' : ''}" onclick="switchPatient('${esc(p.id)}')">
      <div class="opt-n">${esc(p.name)}</div>
      <div class="opt-r">${esc(p.relationship || p.relation || 'Family Member')} · DOB ${esc(p.dob || '—')}</div>
    </div>
  `).join('') + `<div class="add-pat" onclick="openAddPatient()">＋ Add family member</div>`;
}

async function switchPatient(id){
  try{
    await api('/api/patients/switch', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ patientId:id, model:MODEL_NAME })
    });

    currentPatientId = id;
    latestScanData = null;
    closePatientDropdown();
    closeProfileSheet();

    await loadPatients();
    await loadChatHistory();
    await loadTasks().catch(() => {});
    updateDashboard();
    clearChat();
    currentMessages = [];
    currentSessionId = null;

    const p = getPatientById(id);
    if (p) addMsg('ai', `Switched to <strong>${esc(p.name)}</strong>'s profile. How can I help?`, true, true);
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

function renderPatientCard(patient){
  const el = document.getElementById('cardContent');
  if(!el) return;

  if(!patient){
    el.innerHTML = `<div style="color:var(--text3)">No patient loaded.</div>`;
    return;
  }

  const meds = (patient.medications || []).map(m => `<span class="pill p-teal">${esc(m.name)} ${esc(m.dose || '')}</span>`).join('');
  const algs = (patient.allergies || []).map(a => `<span class="pill p-red">⚠️ ${esc(a)}</span>`).join('');

  el.innerHTML = `
    <div class="pc-row"><span class="pc-l">Name</span><span class="pc-v">${esc(patient.name)}</span></div>
    <div class="pc-row"><span class="pc-l">DOB</span><span class="pc-v">${esc(patient.dob || '—')}</span></div>
    <div class="pc-row"><span class="pc-l">Doctor</span><span class="pc-v">${esc(patient.primaryDoctor || '—')}</span></div>
    <div class="pc-row"><span class="pc-l">Insurance</span><span class="pc-v">${esc(patient.insurance?.primary || '—')}</span></div>
    ${meds ? `<div style="margin-top:8px"><div class="s-lbl" style="margin-bottom:4px">Medications</div><div class="pill-row">${meds}</div></div>` : ''}
    ${algs ? `<div style="margin-top:7px"><div class="s-lbl" style="margin-bottom:4px">Allergies</div><div class="pill-row">${algs}</div></div>` : ''}
  `;
}

function renderProfileSheet(patient){
  if(!patient) return;

  const initials = (patient.name || 'P').split(' ').map(w => w[0]).slice(0,2).join('').toUpperCase();
  const age = calcAge(patient.dob);
  const rel = patient.relationship || patient.relation || '';

  ['psAvatar','mobilePatAvatar'].forEach(id => {
    const el = document.getElementById(id);
    if(el) el.textContent = initials;
  });

  setText('psName', patient.name || 'Patient');
  setText('psSub', [age ? `${age}` : null, rel].filter(Boolean).join(' · ') || 'Family Member');
  setText('psCondN', (patient.conditions || []).length);
  setText('psMedN', (patient.medications || []).length);
  setText('psAlgN', (patient.allergies || []).length);
  setText('psDob', patient.dob || '—');
  setText('psDoctor', `${patient.primaryDoctor || '—'} · ${patient.clinic || '—'}`);
  setText('psInsurance', patient.insurance?.primary || '—');
  setText('psPharmacy', `${patient.pharmacy?.name || '—'} ${patient.pharmacy?.phone || ''}`.trim());

  const conds = (patient.conditions || []).map(c => `<span class="pill p-gold">${esc(c)}</span>`).join('');
  const meds = (patient.medications || []).map(m => `<span class="pill p-teal">${esc(m.name)} ${esc(m.dose || '')}</span>`).join('');
  const algs = (patient.allergies || []).map(a => `<span class="pill p-red">⚠️ ${esc(a)}</span>`).join('');

  document.getElementById('psCondPills').innerHTML = conds || '<span style="color:var(--text3);font-size:12px">None</span>';
  document.getElementById('psMedPills').innerHTML = meds || '<span style="color:var(--text3);font-size:12px">None</span>';
  document.getElementById('psAlgPills').innerHTML = algs || '<span style="color:var(--text3);font-size:12px">None</span>';

  const pl = document.getElementById('psPatientList');
  pl.innerHTML = allPatients.map(p => `
    <button onclick="switchPatient('${esc(p.id)}')" style="width:100%;padding:10px 12px;background:${p.id===currentPatientId?'rgba(45,212,191,0.1)':'var(--surface)'};border:1px solid ${p.id===currentPatientId?'rgba(45,212,191,0.2)':'var(--border)'};border-radius:12px;color:var(--text);font-size:13px;cursor:pointer;text-align:left">
      <strong>${esc(p.name)}</strong> <span style="color:var(--text2);font-size:11px">· ${esc(p.relationship || p.relation || 'Family Member')}</span>
    </button>
  `).join('');
}

function togglePatientDropdown(){ document.getElementById('patientDropdown')?.classList.toggle('open'); }
function closePatientDropdown(){ document.getElementById('patientDropdown')?.classList.remove('open'); }

document.addEventListener('click', e => {
  if (!e.target.closest('#patientSelector')) closePatientDropdown();

  const notifOpen =
    e.target.closest('#notifPanel') ||
    e.target.closest('.notif-btn') ||
    e.target.closest('#notifBtnMobileWrap') ||
    e.target.closest('.tb-bell');

  if (!notifOpen) document.getElementById('notifPanel')?.classList.remove('open');
});

/* SHEETS / MODALS */
function openProfileSheet(){ document.getElementById('profileSheet')?.classList.add('open'); lockBody(); }
function closeProfileSheet(){ document.getElementById('profileSheet')?.classList.remove('open'); unlockBody(); }
function openMenuSheet(){ document.getElementById('menuSheet')?.classList.add('open'); lockBody(); }
function closeMenuSheet(){ document.getElementById('menuSheet')?.classList.remove('open'); unlockBody(); }
function openAddPatient(){ closePatientDropdown(); document.getElementById('addPatientModal')?.classList.add('open'); lockBody(); }
function closeAddPatient(){ document.getElementById('addPatientModal')?.classList.remove('open'); unlockBody(); }
function openAddTask(){ document.getElementById('addTaskModal').classList.add('open'); document.getElementById('taskDue').value = new Date(Date.now() + 7 * 86400000).toISOString().split('T')[0]; lockBody(); }
function closeAddTask(){ document.getElementById('addTaskModal').classList.remove('open'); document.getElementById('taskTitle').value = ''; document.getElementById('taskDesc').value = ''; unlockBody(); }
function openCalendarModal(){ document.getElementById('calendarModal').classList.add('open'); seedCalendarDefaults(); lockBody(); }
function closeCalendarModal(){ document.getElementById('calendarModal').classList.remove('open'); unlockBody(); }

/* ADD PATIENT */
async function saveNewPatient(){
  const name = document.getElementById('newName').value.trim();
  if(!name){ alert('Name is required'); return; }

  const patient = {
    name,
    relationship: document.getElementById('newRelation').value.trim() || 'Family Member',
    dob: document.getElementById('newDob').value.trim(),
    primaryDoctor: document.getElementById('newDoctor').value.trim(),
    address: document.getElementById('newAddress').value.trim(),
    insurance: { primary: document.getElementById('newInsurance').value.trim() },
    pharmacy: { name: document.getElementById('newPharmacy').value.trim() },
    conditions: document.getElementById('newConditions').value.split(',').map(s => s.trim()).filter(Boolean),
    allergies: document.getElementById('newAllergies').value.split(',').map(s => s.trim()).filter(Boolean),
    medications: []
  };

  try{
    const data = await api('/api/patients/add', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ ...patient, model:MODEL_NAME })
    });

    closeAddPatient();
    if (data.patient?.id) {
      await switchPatient(data.patient.id);
    } else {
      await loadPatients();
    }
  }catch(e){
    alert(`Error: ${e.message}`);
  }
}

/* CHAT HISTORY */
async function loadChatHistory(){
  try{
    const data = await api('/api/chat-history');
    renderChatHistory(data.sessions || []);
  }catch(e){
    console.error('loadChatHistory', e);
  }
}

function renderChatHistory(sessions){
  const list = document.getElementById('chatHistoryList');
  if(!list) return;

  const filtered = (sessions || []).filter(s => !s.patientId || s.patientId === currentPatientId);

  if(!filtered.length){
    list.innerHTML = `<div style="font-size:12px;color:var(--text3);padding:3px 0">No history yet</div>`;
    return;
  }

  list.innerHTML = filtered.slice(0,20).map(s => `
    <div class="hist-item ${s.id === currentSessionId ? 'active' : ''}" onclick="loadSession('${esc(s.id)}')">
      <span style="flex-shrink:0;margin-top:1px">💬</span>
      <div class="hist-content">
        <div class="hist-preview">${esc(s.preview || 'Chat session')}</div>
        <div class="hist-time">${formatRelTime(s.timestamp)}</div>
      </div>
      <button class="hist-del" onclick="deleteSession(event,'${esc(s.id)}')">✕</button>
    </div>
  `).join('');
}

async function loadSession(id){
  try{
    const session = await api(`/api/chat-history/${encodeURIComponent(id)}`);
    currentSessionId = id;
    currentMessages = Array.isArray(session.messages) ? session.messages : [];
    clearChat(false);

    for (const m of currentMessages) {
      const isUser = m.role === 'user';
      addMsg(isUser ? 'user' : 'ai', m.content || '', false, !isUser);
    }

    closeSidebar();
    await loadChatHistory();
  }catch(e){
    console.error('loadSession', e);
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

async function deleteSession(e, id){
  e.stopPropagation();
  try{
    await api(`/api/chat-history/${encodeURIComponent(id)}`, { method:'DELETE' });
    if (currentSessionId === id) {
      currentSessionId = null;
      currentMessages = [];
      clearChat();
    }
    await loadChatHistory();
  }catch(err){
    addMsg('ai', `❌ ${esc(err.message)}`, true, false);
  }
}

function newChat(){
  if(currentMessages.length > 0) saveChatSession().catch(() => {});
  currentSessionId = null;
  currentMessages = [];
  clearChat();
  loadChatHistory().catch(() => {});
  if (isMobileView()) setMobileState('chat');
}

async function saveChatSession(){
  if(!currentMessages.length) return;
  try{
    await api('/api/save-chat', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ messages: currentMessages, patientId: currentPatientId, model:MODEL_NAME })
    });
  }catch(e){
    console.error('saveChatSession', e);
  }
}

setInterval(() => {
  if (currentMessages.length > 0) saveChatSession().catch(() => {});
}, 30000);

window.addEventListener('beforeunload', () => {
  if(!currentMessages.length) return;
  const blob = new Blob([JSON.stringify({ messages: currentMessages, patientId: currentPatientId, model:MODEL_NAME })], { type:'application/json' });
  navigator.sendBeacon('/api/save-chat', blob);
});

/* NOTIFICATIONS */
async function loadNotifications(){
  try{
    const data = await api('/api/notifications');
    notifications = data.notifications || [];
    renderNotifications();
    updateNotifBadge();
  }catch(e){
    console.error('loadNotifications', e);
  }
}

function renderNotifications(){
  const list = document.getElementById('notifList');
  if(!list) return;

  if(!notifications.length){
    list.innerHTML = `<div class="ni-empty">✅ All clear</div>`;
    return;
  }

  const icons = { medication:'💊', appointment:'📅', insurance:'🛡️', general:'💡' };

  list.innerHTML = notifications.slice(0,20).map(n => `
    <div class="ni ${n.read ? 'read' : 'unread'}" onclick="readNotif('${esc(n.id)}')">
      <div class="ni-head"><span class="ni-dot"></span><span>${icons[n.type] || '🔔'}</span><span class="ni-title">${esc(n.title)}</span></div>
      <div class="ni-msg">${esc(n.message)}</div>
      <div class="ni-time">${formatRelTime(n.createdAt)}</div>
    </div>
  `).join('');
}

function updateNotifBadge(){
  const unread = notifications.filter(n => !n.read).length;
  ['notifBadgeDesktop','notifBadgeMobile'].forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.textContent = unread > 9 ? '9+' : String(unread);
      el.style.display = unread > 0 ? 'flex' : 'none';
    }
  });
}

async function readNotif(id){
  try{
    await api(`/api/notifications/read/${encodeURIComponent(id)}`, { method:'POST' });
    const n = notifications.find(x => x.id === id);
    if(n) n.read = true;
    renderNotifications();
    updateNotifBadge();
  }catch(e){
    console.error('readNotif', e);
  }
}

async function markAllRead(){
  try{
    await api('/api/notifications/read-all', { method:'POST' });
    notifications.forEach(n => { n.read = true; });
    renderNotifications();
    updateNotifBadge();
  }catch(e){
    console.error('markAllRead', e);
  }
}

function toggleNotifications(){
  document.getElementById('notifPanel')?.classList.toggle('open');
}

/* CALENDAR */
async function checkCalendarStatus(){
  try{
    const data = await api('/api/calendar/status');
    calendarConnected = !!data.connected;
    const el = document.getElementById('gcalStatus');
    if(calendarConnected && el){
      el.textContent = '✅ Calendar Connected';
      el.className = 'gcal-s';
      el.removeAttribute('href');
      el.removeAttribute('target');
    }
  }catch(e){
    console.error('checkCalendarStatus', e);
  }
}

function populateCalendarModalFromEvent(event){
  document.getElementById('calTitle').value = event.title || 'Medical appointment';
  document.getElementById('calDate').value = event.date || new Date().toISOString().split('T')[0];
  document.getElementById('calTime').value = event.time || '09:00';
  document.getElementById('calDuration').value = event.duration || 60;
  document.getElementById('calLocation').value = event.location || '';
  document.getElementById('calDescription').value = event.description || '';
}

async function addToCalendar(event){
  pendingCalendarEvent = event;
  populateCalendarModalFromEvent(event);
  openCalendarModal();
}

function downloadICSFile(event){
  const uid = `health-agent-${Date.now()}@local`;
  const now = formatICSDate(new Date());
  const start = formatICSDate(event.start);
  const end = formatICSDate(event.end);

  const clean = (s='') => String(s)
    .replace(/\\/g,'\\\\')
    .replace(/\n/g,'\\n')
    .replace(/,/g,'\\,')
    .replace(/;/g,'\\;');

  const ics = [
    'BEGIN:VCALENDAR',
    'VERSION:2.0',
    'PRODID:-//Health Agent//EN',
    'CALSCALE:GREGORIAN',
    'METHOD:PUBLISH',
    'BEGIN:VEVENT',
    `UID:${uid}`,
    `DTSTAMP:${now}`,
    `DTSTART:${start}`,
    `DTEND:${end}`,
    `SUMMARY:${clean(event.title)}`,
    `DESCRIPTION:${clean(event.description || '')}`,
    `LOCATION:${clean(event.location || '')}`,
    'END:VEVENT',
    'END:VCALENDAR'
  ].join('\r\n');

  const blob = new Blob([ics], { type:'text/calendar;charset=utf-8' });
  const url = URL.createObjectURL(blob);

  const a = document.createElement('a');
  a.href = url;
  a.download = `${(event.title || 'event').replace(/[^\w\-]+/g,'-').toLowerCase() || 'event'}.ics`;
  document.body.appendChild(a);
  a.click();
  a.remove();
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

function addEventToAppleCalendar(){
  try{
    const event = buildCalendarEventFromForm();
    downloadICSFile(event);
    closeCalendarModal();
    addMsg('ai', `📅 Apple Calendar file created for <strong>${esc(event.title)}</strong>. On iPhone, open the downloaded file to add it to Calendar.`, true, true);
    if (isMobileView()) setMobileState('chat');
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

async function addEventToGoogleCalendar(){
  try{
    const event = buildCalendarEventFromForm();

    if (calendarConnected) {
      const data = await api('/api/calendar/add-event', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({
          title: event.title,
          date: event.date,
          time: event.time,
          duration: event.duration,
          location: event.location,
          description: event.description,
          model:MODEL_NAME
        })
      });

      closeCalendarModal();

      if (data.success) {
        const linkHtml = data.link ? ` <a href="${esc(data.link)}" target="_blank" rel="noopener noreferrer">View →</a>` : '';
        addMsg('ai', `✅ Added <strong>${esc(event.title)}</strong> to Google Calendar.${linkHtml}`, true, true);
        if (isMobileView()) setMobileState('chat');
        return;
      }
    }

    const start = event.start.toISOString().replace(/[-:]/g,'').split('.')[0] + 'Z';
    const end = event.end.toISOString().replace(/[-:]/g,'').split('.')[0] + 'Z';

    const url = new URL('https://calendar.google.com/calendar/render');
    url.searchParams.set('action', 'TEMPLATE');
    url.searchParams.set('text', event.title);
    url.searchParams.set('dates', `${start}/${end}`);
    if (event.description) url.searchParams.set('details', event.description);
    if (event.location) url.searchParams.set('location', event.location);

    window.open(url.toString(), '_blank', 'noopener,noreferrer');
    closeCalendarModal();
    addMsg('ai', `📅 Opened Google Calendar for <strong>${esc(event.title)}</strong>.`, true, true);
    if (isMobileView()) setMobileState('chat');
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

function addEventToOutlookCalendar(){
  try{
    const event = buildCalendarEventFromForm();
    const url = new URL('https://outlook.live.com/calendar/0/deeplink/compose');
    url.searchParams.set('subject', event.title);
    url.searchParams.set('startdt', event.start.toISOString());
    url.searchParams.set('enddt', event.end.toISOString());
    if (event.description) url.searchParams.set('body', event.description);
    if (event.location) url.searchParams.set('location', event.location);

    window.open(url.toString(), '_blank', 'noopener,noreferrer');
    closeCalendarModal();
    addMsg('ai', `📅 Opened Outlook Calendar for <strong>${esc(event.title)}</strong>.`, true, true);
    if (isMobileView()) setMobileState('chat');
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

/* CHAT */
function getPrimaryChatArea(){
  return isMobileView() ? document.getElementById('chatArea') : document.getElementById('chatAreaDesktop');
}

function getPrimaryChatInput(){
  return isMobileView() ? document.getElementById('chatInput') : document.getElementById('chatInputDesktop');
}

function clearChat(addWelcome = true){
  const mobileArea = document.getElementById('chatArea');
  const desktopArea = document.getElementById('chatAreaDesktop');

  if (mobileArea) mobileArea.innerHTML = '';
  if (desktopArea) desktopArea.innerHTML = '';

  if(addWelcome){
    const p = getPatientById(currentPatientId);
    const fn = esc((p?.name || 'Linda').split(' ')[0]);
    const html = `
      <div class="welcome-inline" id="welcomeInline">
        <div class="welcome-inline-title">Hi, I’m here for <strong>${fn}</strong>. What do you need?</div>
        <div class="chip-row">
          <button class="chip" onclick="qa('What are her current medications?')">What meds is she taking?</button>
          <button class="chip" onclick="qa('What appointments are coming up?')">What appointments are coming up?</button>
          <button class="chip" onclick="qa('Draft a prior authorization appeal letter for Medicare')">Draft an appeal letter</button>
          <button class="chip" onclick="qa('Check supplement safety')">Check supplement safety</button>
        </div>
      </div>
    `;
    if (mobileArea) mobileArea.innerHTML = html;
    if (desktopArea) desktopArea.innerHTML = html;
  }
}

function syncChatAreas(){
  const mobileArea = document.getElementById('chatArea');
  const desktopArea = document.getElementById('chatAreaDesktop');
  if (!mobileArea || !desktopArea) return;
  if (isMobileView()) {
    desktopArea.innerHTML = mobileArea.innerHTML;
  } else {
    mobileArea.innerHTML = desktopArea.innerHTML;
  }
}

function addMsg(role, content, scroll = true, allowHtml = false){
  const html = `
    <div class="msg ${role === 'user' ? 'user' : 'ai'}">
      <div class="msg-avatar">${role === 'user' ? '👤' : '🤖'}</div>
      <div class="msg-bubble">${allowHtml ? content : esc(String(content || ''))}</div>
    </div>
  `;

  ['chatArea','chatAreaDesktop'].forEach(id => {
    const area = document.getElementById(id);
    if (area) area.insertAdjacentHTML('beforeend', html);
  });

  if(scroll){
    requestAnimationFrame(() => {
      ['chatArea','chatAreaDesktop'].forEach(id => {
        const area = document.getElementById(id);
        if (area) area.scrollTop = area.scrollHeight;
      });
    });
  }
}

function addTypingBubble(id){
  const html = `
    <div class="msg ai" id="${id}">
      <div class="msg-avatar">🤖</div>
      <div class="msg-bubble">
        <div class="typing-indicator"><span></span><span></span><span></span></div>
      </div>
    </div>
  `;
  ['chatArea','chatAreaDesktop'].forEach(areaId => {
    const area = document.getElementById(areaId);
    if (area) {
      area.insertAdjacentHTML('beforeend', html);
      area.scrollTop = area.scrollHeight;
    }
  });
}

function removeTypingBubble(id){
  document.querySelectorAll(`#${CSS.escape(id)}`).forEach(el => el.remove());
}

async function sendMessage(prefilledText = null){
  if (isMobileView()) setMobileState('chat');

  const input = document.getElementById('chatInput');
  const desktopInput = document.getElementById('chatInputDesktop');
  const sourceInput = isMobileView() ? input : desktopInput;
  const raw = prefilledText ?? sourceInput.value;
  const text = String(raw || '').trim();
  if(!text) return;

  input.value = '';
  desktopInput.value = '';
  input.style.height = 'auto';
  desktopInput.style.height = 'auto';

  addMsg('user', text, true, false);
  currentMessages.push({ role:'user', content:text });

  const typingId = `typing-${Date.now()}`;
  addTypingBubble(typingId);

  try{
    const data = await api('/api/chat', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        message:text,
        patientId:currentPatientId,
        model:MODEL_NAME
      })
    });

    removeTypingBubble(typingId);

    const replyText = data.reply || data.error || 'Something went wrong';
    addMsg('ai', formatAssistantText(replyText), true, true);
    currentMessages.push({ role:'assistant', content:replyText });

    if(data.calendarEvent){
      pendingCalendarEvent = data.calendarEvent;
      addCalendarCard(data.calendarEvent);
    }
    if(data.callRequest) addCallCard(data.callRequest);
    if(data.hasPendingEmail) addEmailActionCard();

    await loadNotifications();
  }catch(e){
    removeTypingBubble(typingId);
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

function sendMessageFromDesktop(){
  if (!isMobileView()) sendMessage();
}

function qa(text){
  closeSidebar();
  setMobileState('chat');
  sendMessage(text);
}

function handleKey(e){
  if (isMobileView() && mobileState !== 'chat') setMobileState('chat');
  if(e.key === 'Enter' && !e.shiftKey){
    e.preventDefault();
    sendMessage();
  }
}

function bindDesktopInput(){
  const input = document.getElementById('chatInputDesktop');
  if (!input) return;
  input.addEventListener('keydown', e => {
    if(e.key === 'Enter' && !e.shiftKey){
      e.preventDefault();
      sendMessageFromDesktop();
    }
  });
  input.addEventListener('input', () => autoResize(input));
}

function autoResize(el){
  if (isMobileView() && mobileState !== 'chat') setMobileState('chat');
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
  const mirror = el.id === 'chatInput' ? document.getElementById('chatInputDesktop') : document.getElementById('chatInput');
  if (mirror) {
    mirror.value = el.value;
    mirror.style.height = 'auto';
    mirror.style.height = Math.min(el.scrollHeight, 120) + 'px';
  }
}

/* SCAN */
function renderScanCard(data, fileName = 'Scanned item'){
  latestScanData = { ...data, fileName, patientId: currentPatientId };

  const docType = String(data.document_type || '').toLowerCase();
  const conf = data.confidence || 'low';
  const confClass = conf === 'high' ? 'safe' : conf === 'medium' ? 'warn' : 'info';

  function buildFields(d) {
    const fields = [];
    const add = (label, value) => {
      if (value && value !== 'Unknown' && value !== 'unclear' && value !== 'N/A') {
        fields.push({ label, value: String(value), full: false });
      }
    };
    const addFull = (label, value) => {
      if (value && value !== 'Unknown' && value !== 'unclear' && value !== 'N/A') {
        fields.push({ label, value: String(value), full: true });
      }
    };

    add('Document Type', d.document_type);

    if (docType === 'insurance_card') {
      add('Insurance Co.', d.insurance_company);
      add('Plan Name', d.plan_name);
      add('Member Name', d.member_name);
      add('Member ID', d.member_id);
      add('Group Number', d.group_number);
      add('RX BIN', d.rx_bin);
      add('RX PCN', d.rx_pcn);
      add('RX Group', d.rx_group);
      add('Effective Date', d.effective_date);
      addFull('Copays', typeof d.copay_amounts === 'object' ? JSON.stringify(d.copay_amounts) : d.copay_amounts);
      addFull('Phone Numbers', typeof d.phone_numbers === 'object' ? JSON.stringify(d.phone_numbers) : d.phone_numbers);
    } else if (docType === 'prescription') {
      add('Medication', d.medication_name);
      add('Dosage', d.dosage);
      add('Frequency', d.frequency);
      add('Quantity', d.quantity);
      add('Refills Left', d.refills_remaining);
      add('Prescriber', d.prescriber);
      add('Pharmacy', d.pharmacy_name);
      add('Pharmacy Phone', d.pharmacy_phone);
      add('RX Number', d.rx_number);
      add('Date Filled', d.date_filled);
      add('Expires', d.expiration_date);
      addFull('Warnings', d.warnings);
    } else if (docType === 'lab_result') {
      add('Lab Name', d.lab_name);
      add('Date of Test', d.date_of_test);
      add('Ordering Doctor', d.ordering_doctor);
      add('Patient Name', d.patient_name);
      addFull('Tests', typeof d.test_names === 'object' ? JSON.stringify(d.test_names) : d.test_names);
      addFull('Values', typeof d.values === 'object' ? JSON.stringify(d.values) : d.values);
      addFull('Abnormal Flags', typeof d.abnormal_flags === 'object' ? JSON.stringify(d.abnormal_flags) : d.abnormal_flags);
    } else if (docType === 'medical_bill') {
      add('Provider', d.provider_name);
      add('Date of Service', d.date_of_service);
      add('Total Charge', d.total_charge);
      add('Insurance Paid', d.insurance_paid);
      add('You Owe', d.patient_responsibility);
      add('Claim Number', d.claim_number);
      addFull('Procedure Codes', typeof d.procedure_codes === 'object' ? JSON.stringify(d.procedure_codes) : d.procedure_codes);
    } else if (docType === 'referral') {
      add('Referring Doctor', d.referring_doctor);
      add('Specialist', d.specialist);
      add('Auth Number', d.authorization_number);
      add('Valid Dates', d.valid_dates);
      add('Approved Visits', d.approved_visits);
    } else {
      // Generic fallback — show whatever we got
      add('Brand', d.brand);
      add('Product', d.product_name);
      add('Form', d.form);
      addFull('Purpose', d.purpose);
      addFull('Description', d.description);
    }

    addFull('Summary', d.summary);
    return fields;
  }

  const fields = buildFields(data);
  const fieldsHtml = fields.map(f =>
    `<div class="scan-field${f.full ? ' full' : ''}"><span class="scan-label">${esc(f.label)}</span><span class="scan-value">${esc(f.value)}</span></div>`
  ).join('');

  const typeLabels = {
    insurance_card: '🪪 Insurance Card',
    prescription: '💊 Prescription',
    lab_result: '🧪 Lab Result',
    medical_bill: '💰 Medical Bill',
    referral: '📄 Referral',
    other: '📋 Document'
  };
  const typeLabel = typeLabels[docType] || '📋 Document';

  const cardHtml = `
    <div class="msg ai">
      <div class="msg-avatar">🤖</div>
      <div class="msg-bubble">
        <div class="scan-card">
          <div class="scan-header">
            <div class="scan-icon">📷</div>
            <div class="scan-title">${typeLabel}</div>
            <div class="scan-badges">
              <span class="scan-badge ${confClass}">${esc(conf)} confidence</span>
              <span class="scan-badge info">review before save</span>
            </div>
          </div>

          <p>Scanned <strong>${esc(fileName)}</strong>. Review before saving.</p>

          <div class="scan-grid">${fieldsHtml}</div>

          <div class="scan-actions">
            <button class="scan-btn primary" onclick="confirmScan()">Save to Chart</button>
            <button class="scan-btn" onclick="checkInteractions()">Check Interactions</button>
            <button class="scan-btn" onclick="askDoctor()">Ask Doctor</button>
          </div>

          <div class="scan-foot">AI-assisted extraction. Verify before treating as medical record.</div>
        </div>
      </div>
    </div>
  `;

  ['chatArea','chatAreaDesktop'].forEach(areaId => {
    const area = document.getElementById(areaId);
    if (area) {
      area.insertAdjacentHTML('beforeend', cardHtml);
      area.scrollTop = area.scrollHeight;
    }
  });

  setMobileState('chat');
}

function confirmScan(){
  if(!latestScanData){
    addMsg('ai', '⚠️ No scan is ready to save.', true, false);
    return;
  }

  const title = latestScanData.product_name || latestScanData.fileName || 'Scanned record';
  saveRecentUpload({
    name: latestScanData.fileName || title,
    title,
    type: latestScanData.document_type || 'scan',
    at: new Date().toISOString(),
    patientId: currentPatientId
  });
  updateDashboard();
  addMsg('ai', `✅ Saved <strong>${esc(title)}</strong> to recent records for this patient.`, true, true);
}

function checkInteractions(){
  if(!latestScanData){
    addMsg('ai', '⚠️ Scan something first so I know what to review.', true, false);
    return;
  }
  const product = latestScanData.product_name || latestScanData.fileName || 'this supplement';
  const patient = getPatientById(currentPatientId);
  const meds = (patient?.medications || []).map(m => m.name).filter(Boolean);
  const medLine = meds.length ? `Current meds on file: ${esc(meds.join(', '))}.` : 'No medication list is on file yet.';
  addMsg('ai', `🔎 I can review <strong>${esc(product)}</strong> against the patient profile. ${medLine} Ask me: <em>“Check ${esc(product)} against current meds”</em>.`, true, true);
}

function askDoctor(){
  if(!latestScanData){
    addMsg('ai', '⚠️ Scan something first so I can draft the right message.', true, false);
    return;
  }
  const product = latestScanData.product_name || latestScanData.fileName || 'this supplement';
  const patient = getPatientById(currentPatientId);
  const doctor = patient?.primaryDoctor || 'the provider';
  addMsg('ai', `✉️ Drafting a question for <strong>${esc(doctor)}</strong> about <strong>${esc(product)}</strong> and whether it is appropriate for this patient.`, true, true);
}

/* ACTION CARDS */
function addCalendarCard(event){
  const payload = encodeURIComponent(JSON.stringify(event));
  const html = `
    <div class="action-card calendar">
      <div class="ac-title">📅 Add to Calendar?</div>
      <div class="ac-body"><strong>${esc(event.title)}</strong><br/>${esc(event.date)} at ${esc(event.time || '09:00')} · ${esc(String(event.duration || 60))} min</div>
      <div class="ac-btns">
        <button class="ac-btn success" onclick="addToCalendar(JSON.parse(decodeURIComponent('${payload}')))">Add</button>
        <button class="ac-btn secondary" onclick="removeClosestCard(this)">Dismiss</button>
      </div>
    </div>
  `;
  ['chatArea','chatAreaDesktop'].forEach(areaId => {
    const area = document.getElementById(areaId);
    if (area) {
      area.insertAdjacentHTML('beforeend', html);
      area.scrollTop = area.scrollHeight;
    }
  });
}

function addCallCard(callReq){
  const callId = `call-card-${Date.now()}`;
  const html = `
    <div class="action-card call" data-call-card="${callId}">
      <div class="ac-title">📞 Confirm Phone Call</div>
      <div class="ac-body">Call <strong>${esc(callReq.name)}</strong> at ${esc(callReq.phone || 'unknown')}<br/>Reason: ${esc(callReq.reason || 'Medical inquiry')}</div>
      <div class="ac-btns">
        <button class="ac-btn warn" data-dyn-action="confirm-call" data-card="${callId}">📞 Confirm Call</button>
        <button class="ac-btn secondary" data-dyn-action="cancel-call" data-card="${callId}">Cancel</button>
      </div>
    </div>
  `;
  ['chatArea','chatAreaDesktop'].forEach(areaId => {
    const area = document.getElementById(areaId);
    if (area) {
      area.insertAdjacentHTML('beforeend', html);
      area.scrollTop = area.scrollHeight;
    }
  });

  bindDynamicButton(`[data-dyn-action="confirm-call"][data-card="${callId}"]`, async (_e, btn) => {
    removeCardsByData('call-card', callId);
    await confirmCall();
  });

  bindDynamicButton(`[data-dyn-action="cancel-call"][data-card="${callId}"]`, async (_e, btn) => {
    removeCardsByData('call-card', callId);
    await cancelCall();
  });
}

function addEmailActionCard(){
  const emailId = `email-card-${Date.now()}`;
  const html = `
    <div class="action-card email" data-email-card="${emailId}">
      <div class="ac-title">✉️ Email Draft Ready</div>
      <div class="ac-body">Your email draft is ready. Send it now?</div>
      <div class="ac-btns">
        <button class="ac-btn primary" data-dyn-action="send-email" data-card="${emailId}">📤 Send</button>
        <button class="ac-btn secondary" data-dyn-action="save-email" data-card="${emailId}">Save Draft</button>
      </div>
    </div>
  `;
  ['chatArea','chatAreaDesktop'].forEach(areaId => {
    const area = document.getElementById(areaId);
    if (area) {
      area.insertAdjacentHTML('beforeend', html);
      area.scrollTop = area.scrollHeight;
    }
  });

  bindDynamicButton(`[data-dyn-action="send-email"][data-card="${emailId}"]`, async (_e, btn) => {
    removeCardsByData('email-card', emailId);
    await sendDraftEmail(btn);
  });

  bindDynamicButton(`[data-dyn-action="save-email"][data-card="${emailId}"]`, async () => {
    removeCardsByData('email-card', emailId);
    addMsg('ai', 'Email draft saved.', true, false);
  });
}

function removeClosestCard(btn){
  const card = btn.closest('.action-card');
  if (!card) return;
  const attr = [...card.attributes].find(a => a.name.startsWith('data-'));
  if (attr) {
    const dataName = attr.name.replace('data-','');
    removeCardsByData(dataName, attr.value);
  } else {
    card.remove();
  }
}

function removeCardsByData(attrName, value){
  document.querySelectorAll(`[data-${attrName}="${value}"]`).forEach(el => el.remove());
}

function bindDynamicButton(selector, handler){
  document.querySelectorAll(selector).forEach(el => {
    let fired = false;
    const wrapped = async (e) => {
      if (fired) return;
      fired = true;
      e.preventDefault();
      e.stopPropagation();
      try { await handler(e, el); }
      finally { setTimeout(() => { fired = false; }, 200); }
    };
    el.addEventListener('click', wrapped);
    el.addEventListener('touchend', wrapped, { passive:false });
  });
}

async function confirmCall(){
  try{
    const data = await api('/api/chat', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ message:'confirm call', patientId:currentPatientId, model:MODEL_NAME })
    });
    addMsg('ai', formatAssistantText(data.reply || 'Call confirmed.'), true, true);
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

async function cancelCall(){
  try{
    await api('/api/chat', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ message:'cancel call', patientId:currentPatientId, model:MODEL_NAME })
    });
    addMsg('ai', 'Call cancelled.', true, false);
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

async function sendDraftEmail(){
  try{
    let data;
    try{
      data = await api('/api/send-email', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({ patientId:currentPatientId, model:MODEL_NAME })
      });
    }catch(_err){
      data = await api('/api/chat', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({ message:'send', patientId:currentPatientId, model:MODEL_NAME })
      });
    }
    addMsg('ai', formatAssistantText(data.reply || data.message || 'Email sent.'), true, true);
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

/* FILE UPLOAD */
function triggerUpload(){
  document.getElementById('fileInput')?.click();
}

async function handleFileUpload(input){
  const file = input.files?.[0];
  if(!file) return;

  const pending = document.getElementById('uploadPending');
  document.getElementById('uploadFileName').textContent = `Processing: ${file.name}`;
  pending.classList.add('show');

  const formData = new FormData();
  formData.append('file', file);
  formData.append('model', MODEL_NAME);

  try{
    const res = await fetch('/api/upload', { method:'POST', body:formData });
    const data = await res.json().catch(() => ({}));

    if(!res.ok){
      throw new Error(data.error || `Upload failed (${res.status})`);
    }

    pending.classList.remove('show');

    if(data.pending){
      renderScanCard(data.extracted || {}, file.name);
      setMobileState('chat');
    } else {
      saveRecentUpload({
        name: file.name,
        title: file.name,
        type: 'upload',
        at: new Date().toISOString(),
        patientId: currentPatientId
      });
      updateDashboard();
      addMsg('ai', `📄 ${esc(data.message || 'Upload complete.')}`, true, false);
    }
  }catch(e){
    pending.classList.remove('show');
    addMsg('ai', `❌ Upload error: ${esc(e.message)}`, true, false);
  }finally{
    input.value = '';
  }
}

/* VOICE / EMAIL */
async function startVoiceCall(){
  const patient = getPatientById(currentPatientId);
  let phone = patient?.phone || prompt('Enter phone number to call:');
  if(!phone) return;

  phone = normalizeUSPhone(phone);

  try{
    const data = await api('/api/call', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ phone, reason:'Health check call', patientId:currentPatientId, model:MODEL_NAME })
    });

    addMsg('ai', `📞 Call initiated! ID: ${esc(data.id || 'started')}. Status: ${esc(data.status || 'connecting...')}`, true, false);
  }catch(e){
    addMsg('ai', `❌ Call failed: ${esc(e.message)}`, true, false);
  }
}

function startEmailSend(){
  const patientName = getPatientById(currentPatientId)?.name || 'the patient';
  setMobileState('chat');
  qa(`Draft an email to Dr. Martinez about ${patientName}'s recent lab results`);
}

/* SIDEBAR */
function toggleSidebar(){
  document.getElementById('sidebar')?.classList.toggle('open');
  document.getElementById('sidebarOverlay')?.classList.toggle('show');
}
function closeSidebar(){
  document.getElementById('sidebar')?.classList.remove('open');
  document.getElementById('sidebarOverlay')?.classList.remove('show');
}

/* TASKS */
async function openTaskPanel(){
  document.getElementById('taskPanel')?.classList.add('open');
  document.getElementById('taskPanelOverlay').style.display = 'block';
  closeSidebar();
  closeMenuSheet();
  lockBody();
  await loadTasks();
}

function closeTaskPanel(){
  document.getElementById('taskPanel')?.classList.remove('open');
  document.getElementById('taskPanelOverlay').style.display = 'none';
  unlockBody();
}

async function loadTasks(){
  try{
    const data = await api(`/api/tasks?patientId=${encodeURIComponent(currentPatientId || '')}`);
    allTasks = data.tasks || [];
    renderTasks();
    updateTaskBadge();
    updateDashboard();
  }catch(e){
    console.error('loadTasks', e);
  }
}

function setTaskFilter(status, btn){
  taskFilter = status;
  document.querySelectorAll('.task-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  renderTasks();
}

function renderTasks(){
  const today = new Date().toISOString().split('T')[0];
  let tasks = taskFilter === 'all' ? [...allTasks] : allTasks.filter(t => t.status === taskFilter);

  tasks.sort((a,b) => {
    const p = { high:0, medium:1, low:2 };
    if(a.status === 'done' && b.status !== 'done') return 1;
    if(b.status === 'done' && a.status !== 'done') return -1;
    const priorityDiff = (p[a.priority] ?? 1) - (p[b.priority] ?? 1);
    if(priorityDiff !== 0) return priorityDiff;
    if(a.dueDate && b.dueDate) return a.dueDate.localeCompare(b.dueDate);
    return 0;
  });

  const container = document.getElementById('taskList');
  if(!container) return;

  if(!tasks.length){
    container.innerHTML = `<div style="text-align:center;padding:28px;color:var(--text3);font-size:13px">${taskFilter === 'done' ? '🎉 No completed tasks' : '✅ No tasks here'}</div>`;
    return;
  }

  const ci = { appointment:'📅', medication:'💊', insurance:'🛡️', general:'📌' };

  container.innerHTML = tasks.map(t => {
    const overdue = t.dueDate && t.dueDate < today && t.status !== 'done';
    const ds = t.dueDate ? formatTaskDate(t.dueDate) : '';
    return `
      <div class="task-item ${t.status === 'done' ? 'done' : ''}" data-id="${esc(t.id)}">
        <div class="ti-head">
          <input type="checkbox" class="task-checkbox" ${t.status === 'done' ? 'checked' : ''} onchange="toggleTaskDone('${esc(t.id)}',this.checked)" />
          <span class="t-title ${t.status === 'done' ? 'done' : ''}">${ci[t.category] || '📌'} ${esc(t.title)}</span>
        </div>
        ${t.description ? `<div class="t-desc">${esc(t.description)}</div>` : ''}
        <div class="t-meta">
          ${ds ? `<span class="t-due ${overdue ? 'ov' : ''}">${overdue ? '⚠️ ' : '📅 '}${ds}</span>` : ''}
          <span class="t-pri pri-${esc(t.priority || 'medium')}">${esc(t.priority || 'medium')}</span>
        </div>
        <div class="t-acts">
          ${t.status === 'pending' ? `<button class="t-act" onclick="setTaskStatus('${esc(t.id)}','in-progress')">▶ Start</button>` : ''}
          ${t.status === 'in-progress' ? `<button class="t-act" onclick="setTaskStatus('${esc(t.id)}','pending')">⏸ Pause</button>` : ''}
          <button class="t-act del" onclick="deleteTask('${esc(t.id)}')">🗑</button>
        </div>
      </div>
    `;
  }).join('');
}

function updateTaskBadge(){
  const pending = allTasks.filter(t => t.status !== 'done').length;
  const badge = document.getElementById('taskBadge');
  if(badge){
    badge.textContent = String(pending);
    badge.style.display = pending > 0 ? 'inline' : 'none';
  }
}

async function toggleTaskDone(id, checked){
  try{
    await api(`/api/tasks/${encodeURIComponent(id)}`, {
      method:'PUT',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ status: checked ? 'done' : 'pending', model:MODEL_NAME })
    });
    await loadTasks();
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

async function setTaskStatus(id, status){
  try{
    await api(`/api/tasks/${encodeURIComponent(id)}`, {
      method:'PUT',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ status, model:MODEL_NAME })
    });
    await loadTasks();
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

async function deleteTask(id){
  if(!confirm('Delete this task?')) return;
  try{
    await api(`/api/tasks/${encodeURIComponent(id)}`, { method:'DELETE' });
    allTasks = allTasks.filter(t => t.id !== id);
    renderTasks();
    updateTaskBadge();
    updateDashboard();
  }catch(e){
    addMsg('ai', `❌ ${esc(e.message)}`, true, false);
  }
}

async function saveTask(){
  const title = document.getElementById('taskTitle').value.trim();
  if(!title){ alert('Title is required'); return; }

  try{
    await api('/api/tasks/add', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        title,
        description: document.getElementById('taskDesc').value.trim(),
        dueDate: document.getElementById('taskDue').value,
        priority: document.getElementById('taskPriority').value,
        category: document.getElementById('taskCategory').value,
        patientId: currentPatientId,
        model:MODEL_NAME
      })
    });

    closeAddTask();
    await loadTasks();
  }catch(e){
    alert(`Error: ${e.message}`);
  }
}
</script>
</body>
</html>